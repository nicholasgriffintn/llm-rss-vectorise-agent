    "typescript": "^6.0.2",
    "wrangler": "^4.83.0"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.6.0",
    "prisma": "^7.7.0"
  }
}